{
    "version": "1.0.0",
    "tool": {
        "id": "openai_web_search",
        "name": "Web Search",
        "description": "Allows the model to search the web for real-time information.",
        "category": "discovery",
        "icon": {
            "sfSymbol": "magnifyingglass"
        },
        "requiresApproval": false,
        "tags": [
            "openai",
            "search",
            "web",
            "internet"
        ],
        "trustTierCategory": "provider_capability"
    },
    "execution": {
        "type": "provider_native",
        "provider": "openai"
    },
    "parameters": {
        "filters": {
            "type": "object",
            "description": "Optional filters for the search",
            "required": false
        },
        "enable_image_understanding": {
            "type": "boolean",
            "description": "Enable image understanding in search results",
            "default": false,
            "required": false
        }
    },
    "ai": {
        "systemPromptSection": "### Web Search\nSearch the web for information.\n\n**Usage:**\nEnabled via tool configuration.",
        "webSearch": true
    },
    "sovereignty": {
        "actionCategory": "provider_capability",
        "riskLevel": "low"
    }
}