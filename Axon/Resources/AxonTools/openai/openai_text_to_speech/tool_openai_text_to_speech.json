{
    "version": "1.0.0",
    "tool": {
        "id": "openai_text_to_speech",
        "name": "Text to Speech",
        "description": "Converts text into lifelike spoken audio.",
        "category": "provider",
        "icon": {
            "sfSymbol": "speaker.wave.2.fill"
        },
        "requiresApproval": false,
        "tags": [
            "openai",
            "audio",
            "tts",
            "speech"
        ],
        "trustTierCategory": "provider_capability"
    },
    "execution": {
        "type": "provider_native",
        "provider": "openai"
    },
    "parameters": {
        "input": {
            "type": "string",
            "description": "The text to generate audio for",
            "required": true
        },
        "model": {
            "type": "string",
            "description": "The model to use (e.g., 'gpt-4o-mini-tts', 'tts-1', 'tts-1-hd')",
            "default": "gpt-4o-mini-tts",
            "required": false
        },
        "voice": {
            "type": "string",
            "description": "The voice to use (e.g., 'alloy', 'echo', 'fable', 'onyx', 'nova', 'shimmer')",
            "enum": [
                "alloy",
                "echo",
                "fable",
                "onyx",
                "nova",
                "shimmer",
                "ash",
                "coral",
                "sage"
            ],
            "default": "alloy",
            "required": false
        },
        "response_format": {
            "type": "string",
            "description": "The format of the audio (e.g., 'mp3', 'opus', 'aac', 'flac', 'wav', 'pcm')",
            "default": "mp3",
            "required": false
        },
        "speed": {
            "type": "number",
            "description": "The speed of the generated audio (0.25 to 4.0)",
            "default": 1.0,
            "required": false
        }
    },
    "ai": {
        "systemPromptSection": "### Text to Speech\nGenerate audio from text.",
        "audioGeneration": true
    },
    "sovereignty": {
        "actionCategory": "provider_capability",
        "riskLevel": "low"
    }
}