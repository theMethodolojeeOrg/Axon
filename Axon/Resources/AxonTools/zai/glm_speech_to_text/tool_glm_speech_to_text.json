{
    "version": "1.0.0",
    "tool": {
        "id": "glm_speech_to_text",
        "name": "GLM-ASR",
        "description": "Transcribes audio into text using the GLM-ASR model.",
        "category": "system",
        "icon": {
            "sfSymbol": "waveform.circle.fill"
        },
        "requiresApproval": false,
        "tags": [
            "zai",
            "glm",
            "audio",
            "stt",
            "transcription",
            "asr"
        ],
        "trustTierCategory": "provider_capability"
    },
    "execution": {
        "type": "provider_native",
        "provider": "glm"
    },
    "parameters": {
        "file": {
            "type": "string",
            "description": "Path to the audio file to transcribe",
            "required": true
        },
        "model": {
            "type": "string",
            "description": "The model to use",
            "default": "glm-asr-2512",
            "required": false
        },
        "stream": {
            "type": "boolean",
            "description": "Whether to stream the transcription",
            "default": false,
            "required": false
        }
    },
    "ai": {
        "systemPromptSection": "### Speech to Text\nTranscribe audio using GLM-ASR.",
        "audioTranscription": true
    },
    "sovereignty": {
        "actionCategory": "provider_capability",
        "riskLevel": "low"
    }
}