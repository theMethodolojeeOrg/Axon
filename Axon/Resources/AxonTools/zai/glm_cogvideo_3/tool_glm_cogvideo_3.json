{
    "version": "1.0.0",
    "tool": {
        "id": "glm_cogvideo_3",
        "name": "CogVideoX-3",
        "description": "Generates high-quality videos from text or images using the CogVideoX-3 model.",
        "category": "creative",
        "icon": {
            "sfSymbol": "film.stack.fill"
        },
        "requiresApproval": true,
        "tags": [
            "zai",
            "glm",
            "video",
            "generation",
            "cogvideo"
        ],
        "trustTierCategory": "provider_capability"
    },
    "execution": {
        "type": "provider_native",
        "provider": "glm"
    },
    "parameters": {
        "prompt": {
            "type": "string",
            "description": "Description of the video to generate",
            "required": true
        },
        "image_url": {
            "type": "string",
            "description": "URL of the reference image for image-to-video generation",
            "required": false
        },
        "model": {
            "type": "string",
            "description": "The model to use",
            "default": "cogvideox-3",
            "required": false
        },
        "quality": {
            "type": "string",
            "description": "Output mode: 'quality' or 'speed'",
            "enum": [
                "quality",
                "speed"
            ],
            "default": "quality",
            "required": false
        },
        "with_audio": {
            "type": "boolean",
            "description": "Whether to generate audio for the video",
            "default": true,
            "required": false
        },
        "size": {
            "type": "string",
            "description": "Video resolution (e.g., '1920x1080')",
            "default": "1920x1080",
            "required": false
        },
        "fps": {
            "type": "integer",
            "description": "Frame rate (30 or 60)",
            "enum": [
                30,
                60
            ],
            "default": 30,
            "required": false
        }
    },
    "ai": {
        "systemPromptSection": "### Video Generation\nGenerate videos using CogVideoX-3.",
        "videoGeneration": true
    },
    "sovereignty": {
        "actionCategory": "provider_capability",
        "riskLevel": "medium"
    }
}