{
    "version": "1.0.0",
    "tool": {
        "id": "glm_cogview_4",
        "name": "CogView-4",
        "description": "Generates high-quality images from text descriptions using the CogView-4 model.",
        "category": "creative",
        "icon": {
            "sfSymbol": "paintpalette.fill"
        },
        "requiresApproval": true,
        "tags": [
            "zai",
            "glm",
            "image",
            "generation",
            "cogview"
        ],
        "trustTierCategory": "provider_capability"
    },
    "execution": {
        "type": "provider_native",
        "provider": "glm"
    },
    "parameters": {
        "prompt": {
            "type": "string",
            "description": "Description of the image to generate",
            "required": true
        },
        "model": {
            "type": "string",
            "description": "The model to use",
            "default": "cogView-4-250304",
            "required": false
        },
        "size": {
            "type": "string",
            "description": "Size of the generated image (e.g., '1024x1024')",
            "default": "1024x1024",
            "required": false
        }
    },
    "ai": {
        "systemPromptSection": "### Image Generation\nGenerate images using CogView-4.",
        "imageGeneration": true
    },
    "sovereignty": {
        "actionCategory": "provider_capability",
        "riskLevel": "medium"
    }
}