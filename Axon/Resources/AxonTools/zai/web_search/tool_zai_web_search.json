{
  "version": "1.0.0",
  "tool": {
    "id": "zai_web_search",
    "name": "zAI Web Search",
    "description": "Search the web using zAI's models.",
    "category": "search",
    "icon": { "sfSymbol": "magnifyingglass.circle.fill" },
    "requiresApproval": false,
    "tags": ["search", "web", "zai"]
  },
  "parameters": {
    "query": {
      "type": "string",
      "required": true,
      "description": "Search query"
    }
  },
  "inputFormat": { "style": "json" },
  "execution": {
    "type": "provider_native",
    "handler": "zai",
    "provider": "zai",
    "nativeToolName": "zai_web_search"
  },
  "ai": {
    "systemPromptSection": "### zai_web_search\nSearch the web using zAI.\n\n**Format:**\n```tool_request\n{\"tool\": \"zai_web_search\", \"query\": \"search topic\"}\n```",
    "usageExamples": [
      { "description": "Search", "input": "{\"query\": \"latest news\"}" }
    ],
    "whenToUse": [
      "Need current information"
    ],
    "whenNotToUse": [
      "Local file searches"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        { "param": "query", "widget": "text_field", "label": "Search Query", "placeholder": "What do you want to search?" }
      ],
      "layout": "vertical",
      "submitLabel": "Search"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        { "type": "header", "title": "Search Results", "icon": "magnifyingglass.circle.fill" },
        { "type": "markdown", "source": "{{output}}" }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "web_search",
    "approvalDescription": "Search web: {{query}}",
    "scopes": ["web.search"],
    "riskLevel": "low"
  },
  "requirements": {
    "apiKey": "zaiApiKey",
    "provider": "zai"
  }
}
