{
  "version": "1.0.0",
  "tool": {
    "id": "url_context",
    "name": "URL Context",
    "description": "Fetch and analyze content from web URLs, PDFs, and articles.",
    "category": "web",
    "icon": { "sfSymbol": "link" },
    "requiresApproval": false,
    "tags": ["url", "web", "fetch", "pdf", "article"]
  },
  "parameters": {
    "urls": {
      "type": "array",
      "required": false,
      "description": "List of URLs to fetch and analyze",
      "items": { "type": "string" }
    }
  },
  "inputFormat": { "style": "json" },
  "execution": {
    "type": "provider_native",
    "handler": "gemini",
    "provider": "gemini",
    "nativeToolName": "url_context"
  },
  "ai": {
    "systemPromptSection": "### url_context\nFetch and read web page content, PDFs, and articles.\n\n**Format:**\n```tool_request\n{\"tool\": \"url_context\", \"query\": \"{\\\"urls\\\": [\\\"https://example.com/article\\\"]}\"}\n```\n\n**Capabilities:**\n- Fetch web page content\n- Analyze PDFs and documents\n- Extract information from articles\n- Automatic URL detection in conversation",
    "usageExamples": [
      { "description": "Fetch article", "input": "{\"urls\": [\"https://example.com/article\"]}" },
      { "description": "Multiple URLs", "input": "{\"urls\": [\"https://example.com/page1\", \"https://example.com/page2\"]}" }
    ],
    "whenToUse": [
      "User shares a URL to analyze",
      "Need to read specific web content",
      "Extracting info from online documents"
    ],
    "whenNotToUse": [
      "General web search (use google_search)",
      "Local file access"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        { "param": "urls", "widget": "tag_input", "label": "URLs", "placeholder": "Enter URLs to fetch" }
      ],
      "layout": "vertical",
      "submitLabel": "Fetch"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        { "type": "header", "title": "URL Content", "icon": "link" },
        { "type": "markdown", "source": "{{output}}" }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "web_fetch",
    "approvalDescription": "Fetch URL content",
    "scopes": ["web.fetch"],
    "riskLevel": "low"
  },
  "requirements": {
    "apiKey": "geminiApiKey",
    "provider": "gemini"
  }
}
