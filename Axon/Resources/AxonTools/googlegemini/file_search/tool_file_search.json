{
  "version": "1.0.0",
  "tool": {
    "id": "file_search",
    "name": "File Search",
    "description": "Semantic RAG search over documents in File Search Stores.",
    "category": "search",
    "icon": { "sfSymbol": "doc.text.magnifyingglass" },
    "requiresApproval": false,
    "tags": ["file", "search", "rag", "documents", "semantic"]
  },
  "parameters": {
    "query": {
      "type": "string",
      "required": true,
      "description": "Search query for documents"
    },
    "file_search_store_names": {
      "type": "array",
      "required": false,
      "description": "File search store names to query",
      "items": { "type": "string" }
    }
  },
  "inputFormat": { "style": "json" },
  "execution": {
    "type": "provider_native",
    "handler": "gemini",
    "provider": "gemini",
    "nativeToolName": "file_search"
  },
  "ai": {
    "systemPromptSection": "### file_search\nSemantic RAG search over uploaded documents.\n\n**Format:**\n```tool_request\n{\"tool\": \"file_search\", \"query\": \"What are the key findings in the report?\"}\n```\n\n**Capabilities:**\n- Semantic search over documents\n- PDF and text file analysis\n- Citation extraction\n\n**Requirements:** Requires active File Search Store with uploaded documents.",
    "usageExamples": [
      { "description": "Search documents", "input": "{\"query\": \"What are the key findings?\"}" },
      { "description": "Specific store", "input": "{\"query\": \"budget projections\", \"file_search_store_names\": [\"financial-docs\"]}" }
    ],
    "whenToUse": [
      "Searching uploaded documents",
      "Finding specific info in PDFs",
      "Document Q&A"
    ],
    "whenNotToUse": [
      "Web search (use google_search)",
      "No documents uploaded"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        { "param": "query", "widget": "text_field", "label": "Search Query", "placeholder": "What are you looking for?" },
        { "param": "file_search_store_names", "widget": "tag_input", "label": "Store Names (optional)" }
      ],
      "layout": "vertical",
      "submitLabel": "Search"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        { "type": "header", "title": "Document Search", "icon": "doc.text.magnifyingglass" },
        { "type": "markdown", "source": "{{output}}" }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "file_search",
    "approvalDescription": "Search documents",
    "scopes": ["file.search"],
    "riskLevel": "low"
  },
  "requirements": {
    "apiKey": "geminiApiKey",
    "provider": "gemini",
    "fileSearchStore": true
  }
}
