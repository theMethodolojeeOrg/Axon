{
    "version": "1.0.0",
    "tool": {
        "id": "gemini_audio_understanding",
        "name": "Audio Understanding",
        "description": "Analyzes audio content to summarize, describe, or answer questions about recordings.",
        "category": "system",
        "icon": {
            "sfSymbol": "waveform.circle"
        },
        "requiresApproval": false,
        "tags": [
            "gemini",
            "audio",
            "understanding",
            "analysis"
        ],
        "trustTierCategory": "provider_capability"
    },
    "execution": {
        "type": "provider_native",
        "provider": "google"
    },
    "parameters": {
        "file": {
            "type": "string",
            "description": "Path to the audio file to analyze",
            "required": true
        },
        "prompt": {
            "type": "string",
            "description": "Instructions for analysis (e.g., 'Describe this audio')",
            "default": "Describe this audio",
            "required": true
        },
        "model": {
            "type": "string",
            "description": "The model to use",
            "default": "gemini-2.5-flash",
            "required": false
        }
    },
    "ai": {
        "systemPromptSection": "### Audio Understanding\nAnalyze audio content using Gemini.",
        "audioUnderstanding": true
    },
    "sovereignty": {
        "actionCategory": "provider_capability",
        "riskLevel": "low"
    }
}
