{
  "version": "1.0.0",
  "tool": {
    "id": "gemini_video_gen",
    "name": "Gemini Video Generation",
    "description": "Generate videos from text prompts using Google's Veo 3.1 model.",
    "category": "generation",
    "icon": { "sfSymbol": "video.badge.waveform" },
    "requiresApproval": false,
    "tags": ["video", "generation", "veo", "ai", "creative"]
  },
  "parameters": {
    "prompt": {
      "type": "string",
      "required": true,
      "description": "Description of the video to generate"
    },
    "negative_prompt": {
      "type": "string",
      "required": false,
      "description": "What to exclude from the video"
    },
    "duration_seconds": {
      "type": "enum",
      "required": false,
      "description": "Video duration in seconds",
      "enum": ["4", "6", "8"],
      "enumDescriptions": {
        "4": "4 seconds (fastest)",
        "6": "6 seconds",
        "8": "8 seconds (longest)"
      },
      "default": "4"
    },
    "aspect_ratio": {
      "type": "enum",
      "required": false,
      "description": "Video aspect ratio",
      "enum": ["16:9", "9:16"],
      "enumDescriptions": {
        "16:9": "Landscape (widescreen)",
        "9:16": "Portrait (vertical)"
      },
      "default": "16:9"
    }
  },
  "inputFormat": { "style": "json" },
  "execution": {
    "type": "provider_native",
    "handler": "gemini",
    "provider": "gemini",
    "nativeToolName": "gemini_video_gen",
    "model": "veo-3.1-generate-preview",
    "longRunning": true,
    "pollingInterval": 10000
  },
  "ai": {
    "systemPromptSection": "### gemini_video_gen\nGenerate videos using Veo 3.1.\n\n**Format:**\n```tool_request\n{\"tool\": \"gemini_video_gen\", \"query\": \"{\\\"prompt\\\": \\\"A serene sunset over mountains\\\", \\\"duration_seconds\\\": \\\"6\\\"}\"}\n```\n\n**Parameters:**\n- prompt: Video description (required)\n- negative_prompt: What to exclude\n- duration_seconds: 4, 6, or 8 (default: 4)\n- aspect_ratio: \"16:9\" or \"9:16\" (default: 16:9)\n\n**Note:** Video generation takes 30-120 seconds. Audio is included.",
    "usageExamples": [
      { "description": "Simple video", "input": "{\"prompt\": \"A cat playing with yarn\"}" },
      { "description": "With options", "input": "{\"prompt\": \"Cinematic drone shot of mountains\", \"duration_seconds\": \"8\", \"aspect_ratio\": \"16:9\"}" }
    ],
    "whenToUse": [
      "Creating short video clips",
      "Visual storytelling",
      "Creative content generation"
    ],
    "whenNotToUse": [
      "Long-form video content",
      "Real-time video needs",
      "Person generation (blocked)"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        { "param": "prompt", "widget": "textarea", "label": "Video Description", "placeholder": "Describe the video you want to create...", "rows": 3 },
        { "param": "negative_prompt", "widget": "text_field", "label": "Exclude (optional)", "placeholder": "What to avoid in the video" },
        { "param": "duration_seconds", "widget": "segmented", "label": "Duration", "options": [
          { "value": "4", "label": "4s" },
          { "value": "6", "label": "6s" },
          { "value": "8", "label": "8s" }
        ]},
        { "param": "aspect_ratio", "widget": "segmented", "label": "Aspect Ratio", "options": [
          { "value": "16:9", "label": "Landscape" },
          { "value": "9:16", "label": "Portrait" }
        ]}
      ],
      "layout": "vertical",
      "submitLabel": "Generate Video"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        { "type": "header", "title": "Video Generated", "icon": "video.badge.waveform" },
        { "type": "video", "source": "{{videoUri}}" }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "content_generate",
    "approvalDescription": "Generate video: {{prompt}}",
    "scopes": ["content.generate"],
    "riskLevel": "low"
  },
  "requirements": {
    "apiKey": "geminiApiKey",
    "provider": "gemini"
  }
}
