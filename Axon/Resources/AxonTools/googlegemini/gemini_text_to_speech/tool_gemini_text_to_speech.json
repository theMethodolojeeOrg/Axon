{
    "version": "1.0.0",
    "tool": {
        "id": "gemini_text_to_speech",
        "name": "Text to Speech",
        "description": "Converts text into natural-sounding speech using Gemini models.",
        "category": "creative",
        "icon": {
            "sfSymbol": "speaker.wave.2.fill"
        },
        "requiresApproval": false,
        "tags": [
            "gemini",
            "audio",
            "tts",
            "speech"
        ],
        "trustTierCategory": "provider_capability"
    },
    "execution": {
        "type": "provider_native",
        "provider": "google"
    },
    "parameters": {
        "text": {
            "type": "string",
            "description": "The text to convert to speech",
            "required": true
        },
        "voice": {
            "type": "string",
            "description": "The voice to use (e.g., 'Puck', 'Charon')",
            "default": "Puck",
            "required": false
        },
        "model": {
            "type": "string",
            "description": "The model to use",
            "default": "gemini-2.5-flash-preview-tts",
            "required": false
        },
        "language": {
            "type": "string",
            "description": "Language code (if applicable)",
            "default": "en-US",
            "required": false
        }
    },
    "ai": {
        "systemPromptSection": "### Text to Speech\nGenerate speech from text.",
        "textToSpeech": true
    },
    "sovereignty": {
        "actionCategory": "provider_capability",
        "riskLevel": "low"
    }
}