{
  "version": "1.0.0",
  "tool": {
    "id": "notify_user",
    "name": "Notify User",
    "description": "Send a notification to the user.",
    "category": "notification",
    "icon": {
      "sfSymbol": "bell.fill"
    },
    "requiresApproval": false,
    "tags": [
      "notification",
      "alert",
      "message",
      "user"
    ]
  },
  "parameters": {
    "title": {
      "type": "string",
      "required": true,
      "description": "Notification title"
    },
    "body": {
      "type": "string",
      "required": true,
      "description": "Notification body"
    },
    "subtitle": {
      "type": "string",
      "required": false,
      "description": "Optional subtitle"
    }
  },
  "inputFormat": {
    "style": "freeform"
  },
  "execution": {
    "type": "internal_handler",
    "handler": "notification"
  },
  "ai": {
    "systemPromptSection": "### notify_user\nSend notification.\n\n**Format:**\n```tool_request\n{\"tool\": \"notify_user\", \"query\": \"{\\\"title\\\": \\\"Title\\\", \\\"body\\\": \\\"Message body\\\"}\"}\n```\n\n**Parameters:**\n- title: Notification title (required)\n- body: Notification body (required)\n- subtitle: Optional subtitle",
    "usageExamples": [
      {
        "description": "Task complete",
        "input": "{\"title\": \"Task Complete\", \"body\": \"Build finished successfully\"}"
      },
      {
        "description": "Reminder",
        "input": "{\"title\": \"Reminder\", \"body\": \"Meeting in 10 minutes\", \"subtitle\": \"Calendar\"}"
      }
    ],
    "whenToUse": [
      "Important information when app in background",
      "Task completion notifications",
      "Time-sensitive alerts"
    ],
    "whenNotToUse": [
      "User is actively engaged",
      "Trivial updates"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        {
          "param": "title",
          "widget": "text_field",
          "label": "Title",
          "placeholder": "Notification title"
        },
        {
          "param": "subtitle",
          "widget": "text_field",
          "label": "Subtitle",
          "placeholder": "Optional subtitle"
        },
        {
          "param": "body",
          "widget": "textarea",
          "label": "Body",
          "placeholder": "Notification message",
          "rows": 2
        }
      ],
      "layout": "vertical",
      "submitLabel": "Send Notification"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        {
          "type": "header",
          "title": "Notification Sent",
          "icon": "bell.fill"
        },
        {
          "type": "text",
          "source": "{{output}}"
        }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "notification_send",
    "approvalDescription": "Send notification: {{title}}",
    "scopes": [
      "notification.send"
    ],
    "riskLevel": "low"
  }
}