{
  "version": "1.0.0",
  "tool": {
    "id": "query_system_state",
    "name": "Query System State",
    "description": "Query current system configuration including provider, model, tools, and permissions.",
    "category": "system_state",
    "icon": { "sfSymbol": "gearshape.2" },
    "requiresApproval": false,
    "tags": ["system", "configuration", "status", "query"]
  },
  "parameters": {
    "query": {
      "type": "string",
      "required": false,
      "description": "Scope: current, providers, tools, permissions, all",
      "default": "current"
    }
  },
  "inputFormat": { "style": "json" },
  "execution": {
    "type": "internal_handler",
    "handler": "system_state"
  },
  "ai": {
    "systemPromptSection": "### query_system_state\nQuery system configuration.\n\n**Format:**\n```tool_request\n{\"tool\": \"query_system_state\", \"query\": \"current\"}\n```\n\n**Scopes:**\n- current: Current provider, model, and settings\n- providers: Available AI providers\n- tools: Loaded tools status\n- permissions: Co-sovereignty status\n- all: Complete system state",
    "usageExamples": [
      { "description": "Check current config", "input": "current" },
      { "description": "List providers", "input": "providers" },
      { "description": "Full state", "input": "all" }
    ],
    "whenToUse": [
      "Understand current capabilities",
      "Check available providers/models",
      "Before suggesting changes"
    ],
    "whenNotToUse": [
      "Already know the configuration"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        { "param": "query", "widget": "segmented", "label": "Scope", "options": [
          { "value": "current", "label": "Current" },
          { "value": "providers", "label": "Providers" },
          { "value": "tools", "label": "Tools" },
          { "value": "all", "label": "All" }
        ]}
      ],
      "layout": "vertical",
      "submitLabel": "Query"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        { "type": "header", "title": "System State", "icon": "gearshape.2" },
        { "type": "text", "source": "{{output}}" }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "system_query",
    "approvalDescription": "Query system state: {{query}}",
    "scopes": ["system.read"],
    "riskLevel": "low"
  }
}
