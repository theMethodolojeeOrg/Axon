{
  "version": "1.0.0",
  "tool": {
    "id": "heartbeat_set_delivery_profile",
    "name": "Set Delivery Profile",
    "description": "Set the active heartbeat delivery profile.",
    "category": "heartbeat",
    "icon": {
      "sfSymbol": "person.badge.clock"
    },
    "requiresApproval": false,
    "tags": [
      "heartbeat",
      "profile",
      "delivery"
    ]
  },
  "parameters": {
    "profile_id": {
      "type": "string",
      "required": true,
      "description": "Profile ID to activate"
    }
  },
  "inputFormat": {
    "style": "freeform"
  },
  "execution": {
    "type": "internal_handler",
    "handler": "heartbeat"
  },
  "ai": {
    "systemPromptSection": "### heartbeat_set_delivery_profile\nSet active delivery profile.\n\n**Format:**\n```tool_request\n{\"tool\": \"heartbeat_set_delivery_profile\", \"query\": \"{\\\"profile_id\\\": \\\"morning_brief\\\"}\"}\n```\n\n**Note:** Profile must already exist.",
    "usageExamples": [
      {
        "description": "Set morning profile",
        "input": "{\"profile_id\": \"morning_brief\"}"
      },
      {
        "description": "Set minimal profile",
        "input": "{\"profile_id\": \"minimal\"}"
      }
    ],
    "whenToUse": [
      "Switch heartbeat content format",
      "User preference for different delivery style"
    ],
    "whenNotToUse": [
      "Profile doesn't exist"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        {
          "param": "profile_id",
          "widget": "text_field",
          "label": "Profile ID",
          "placeholder": "Enter profile ID..."
        }
      ],
      "layout": "vertical",
      "submitLabel": "Set Profile"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        {
          "type": "header",
          "title": "Profile Set",
          "icon": "person.badge.clock"
        },
        {
          "type": "text",
          "source": "{{output}}"
        }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "heartbeat_configure",
    "approvalDescription": "Set delivery profile: {{profile_id}}",
    "scopes": [
      "heartbeat.configure"
    ],
    "riskLevel": "low"
  }
}