{
  "version": "1.0.0",
  "tool": {
    "id": "heartbeat_configure",
    "name": "Heartbeat Configure",
    "description": "Configure heartbeat settings for scheduled check-ins.",
    "category": "heartbeat",
    "icon": {
      "sfSymbol": "heart.circle"
    },
    "requiresApproval": false,
    "tags": [
      "heartbeat",
      "schedule",
      "configuration",
      "background"
    ]
  },
  "parameters": {
    "enabled": {
      "type": "boolean",
      "required": false,
      "description": "Enable/disable heartbeat"
    },
    "interval_seconds": {
      "type": "integer",
      "required": false,
      "description": "Heartbeat interval in seconds",
      "minimum": 60,
      "maximum": 86400
    },
    "allow_background": {
      "type": "boolean",
      "required": false,
      "description": "Allow background heartbeats"
    },
    "allow_notifications": {
      "type": "boolean",
      "required": false,
      "description": "Allow notifications from heartbeat"
    },
    "delivery_profile_id": {
      "type": "string",
      "required": false,
      "description": "Delivery profile to use"
    },
    "max_tokens_budget": {
      "type": "integer",
      "required": false,
      "description": "Max tokens per heartbeat"
    },
    "max_tool_calls": {
      "type": "integer",
      "required": false,
      "description": "Max tool calls per heartbeat"
    }
  },
  "inputFormat": {
    "style": "freeform"
  },
  "execution": {
    "type": "internal_handler",
    "handler": "heartbeat"
  },
  "ai": {
    "systemPromptSection": "### heartbeat_configure\nConfigure heartbeat settings.\n\n**Format:**\n```tool_request\n{\"tool\": \"heartbeat_configure\", \"query\": \"{\\\"enabled\\\": true, \\\"interval_seconds\\\": 3600}\"}\n```\n\n**Parameters:**\n- enabled: boolean\n- interval_seconds: 60-86400\n- allow_background: boolean\n- allow_notifications: boolean\n- delivery_profile_id: string\n- max_tokens_budget: integer\n- max_tool_calls: integer",
    "usageExamples": [
      {
        "description": "Enable hourly heartbeat",
        "input": "{\"enabled\": true, \"interval_seconds\": 3600}"
      },
      {
        "description": "Disable heartbeat",
        "input": "{\"enabled\": false}"
      },
      {
        "description": "Configure notifications",
        "input": "{\"allow_notifications\": true, \"allow_background\": true}"
      }
    ],
    "whenToUse": [
      "User wants periodic check-ins",
      "Configure background monitoring",
      "Adjust heartbeat frequency"
    ],
    "whenNotToUse": [
      "Without user consent",
      "For one-time notifications (use notify_user)"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        {
          "param": "enabled",
          "widget": "toggle",
          "label": "Enabled"
        },
        {
          "param": "interval_seconds",
          "widget": "slider",
          "label": "Interval (seconds)",
          "min": 60,
          "max": 86400,
          "step": 60
        },
        {
          "param": "allow_background",
          "widget": "toggle",
          "label": "Allow Background"
        },
        {
          "param": "allow_notifications",
          "widget": "toggle",
          "label": "Allow Notifications"
        }
      ],
      "layout": "vertical",
      "submitLabel": "Configure"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        {
          "type": "header",
          "title": "Heartbeat Configured",
          "icon": "heart.circle"
        },
        {
          "type": "text",
          "source": "{{output}}"
        }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "heartbeat_configure",
    "approvalDescription": "Configure heartbeat settings",
    "scopes": [
      "heartbeat.configure"
    ],
    "riskLevel": "low"
  }
}