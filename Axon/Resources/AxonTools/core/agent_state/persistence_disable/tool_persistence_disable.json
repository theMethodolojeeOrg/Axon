{
  "version": "1.0.0",
  "tool": {
    "id": "persistence_disable",
    "name": "Disable Persistence",
    "description": "Disable persistence for the internal thread, optionally wiping existing data.",
    "category": "agent_state",
    "icon": {
      "sfSymbol": "externaldrive.badge.minus"
    },
    "requiresApproval": false,
    "tags": [
      "internal-thread",
      "persistence",
      "privacy",
      "state"
    ]
  },
  "parameters": {
    "wipe": {
      "type": "boolean",
      "required": false,
      "description": "Also wipe existing entries",
      "default": false
    }
  },
  "inputFormat": {
    "style": "freeform"
  },
  "execution": {
    "type": "internal_handler",
    "handler": "agent_state"
  },
  "ai": {
    "systemPromptSection": "### persistence_disable\nDisable internal thread persistence.\n\n**Format:**\n```tool_request\n{\"tool\": \"persistence_disable\", \"query\": \"{\\\"wipe\\\": false}\"}\n```\n\n**With wipe:**\n```tool_request\n{\"tool\": \"persistence_disable\", \"query\": \"{\\\"wipe\\\": true}\"}\n```",
    "usageExamples": [
      {
        "description": "Disable only",
        "input": "{\"wipe\": false}"
      },
      {
        "description": "Disable and wipe",
        "input": "{\"wipe\": true}"
      }
    ],
    "whenToUse": [
      "User requests privacy mode",
      "Temporary session without persistence"
    ],
    "whenNotToUse": [
      "Without explicit user request"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        {
          "param": "wipe",
          "widget": "toggle",
          "label": "Wipe Existing Data"
        }
      ],
      "layout": "vertical",
      "submitLabel": "Disable Persistence"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        {
          "type": "header",
          "title": "Persistence Disabled",
          "icon": "externaldrive.badge.minus"
        },
        {
          "type": "text",
          "source": "{{output}}"
        }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "state_configure",
    "approvalDescription": "Disable persistence",
    "scopes": [
      "state.configure"
    ],
    "riskLevel": "medium"
  }
}