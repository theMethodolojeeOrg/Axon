{
  "version": "1.0.0",
  "tool": {
    "id": "agent_state_append",
    "name": "Internal Thread Append",
    "description": "Append an entry to the internal thread (AI's private workspace for notes, observations, and plans).",
    "category": "agent_state",
    "icon": { "sfSymbol": "doc.text.fill" },
    "requiresApproval": false,
    "tags": ["internal-thread", "notes", "workspace", "state"]
  },
  "parameters": {
    "kind": {
      "type": "enum",
      "required": false,
      "description": "Type of entry",
      "enum": ["note", "observation", "plan", "question", "insight"],
      "enumDescriptions": {
        "note": "General note or working thought",
        "observation": "Observation about user or context",
        "plan": "Plan or strategy for a task",
        "question": "Question to investigate later",
        "insight": "Key insight or realization"
      },
      "default": "note"
    },
    "content": {
      "type": "string",
      "required": true,
      "description": "The content to append",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "required": false,
      "description": "Tags for categorization and retrieval",
      "items": { "type": "string" }
    },
    "visibility": {
      "type": "enum",
      "required": false,
      "description": "Who can see this entry",
      "enum": ["userVisible", "aiOnly", "systemOnly"],
      "enumDescriptions": {
        "userVisible": "Visible to both user and AI",
        "aiOnly": "Only visible to AI",
        "systemOnly": "System internal use only"
      },
      "default": "userVisible"
    }
  },
  "inputFormat": { "style": "json" },
  "execution": {
    "type": "internal_handler",
    "handler": "agent_state"
  },
  "ai": {
    "systemPromptSection": "### agent_state_append\nAppend entry to internal thread.\n\n**Format:**\n```tool_request\n{\"tool\": \"agent_state_append\", \"query\": \"{\\\"kind\\\": \\\"note\\\", \\\"content\\\": \\\"Your note here\\\", \\\"tags\\\": [\\\"tag1\\\"], \\\"visibility\\\": \\\"userVisible\\\"}\"}\n```",
    "usageExamples": [
      { "description": "Add a note", "input": "{\"kind\": \"note\", \"content\": \"User prefers detailed explanations\", \"tags\": [\"preferences\"]}" },
      { "description": "Private observation", "input": "{\"kind\": \"observation\", \"content\": \"User seems frustrated\", \"visibility\": \"aiOnly\"}" }
    ],
    "whenToUse": [
      "Track working notes during complex tasks",
      "Record observations for later reference",
      "Outline plans before execution"
    ],
    "whenNotToUse": [
      "Long-term memories (use create_memory)",
      "Temporary calculations"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        { "param": "kind", "widget": "segmented", "label": "Type" },
        { "param": "content", "widget": "textarea", "label": "Content", "rows": 3 },
        { "param": "tags", "widget": "tag_input", "label": "Tags" },
        { "param": "visibility", "widget": "picker", "label": "Visibility" }
      ],
      "layout": "vertical",
      "submitLabel": "Append"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        { "type": "header", "title": "Entry Added", "icon": "checkmark.circle.fill" },
        { "type": "badge", "source": "{{kind}}" },
        { "type": "text", "source": "{{content}}" }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "state_write",
    "approvalDescription": "Append {{kind}} to internal thread",
    "scopes": ["state.write"],
    "riskLevel": "low"
  }
}
