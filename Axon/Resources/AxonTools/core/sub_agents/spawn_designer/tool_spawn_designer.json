{
  "version": "1.0.0",
  "tool": {
    "id": "spawn_designer",
    "name": "Spawn Designer",
    "description": "Spawn a meta-reasoning sub-agent for planning and architecture tasks.",
    "category": "sub_agents",
    "icon": { "sfSymbol": "pencil.and.ruler" },
    "requiresApproval": true,
    "tags": ["sub-agent", "designer", "planning", "architecture"]
  },
  "parameters": {
    "task": {
      "type": "string",
      "required": true,
      "description": "Task description for the designer"
    },
    "context_tags": {
      "type": "array",
      "required": false,
      "description": "Context tags to provide",
      "items": { "type": "string" }
    },
    "model_tier": {
      "type": "enum",
      "required": false,
      "description": "Model tier to use",
      "enum": ["capable", "fast"],
      "enumDescriptions": {
        "capable": "More capable model for complex reasoning",
        "fast": "Faster model for simpler planning"
      },
      "default": "capable"
    }
  },
  "inputFormat": { "style": "json" },
  "execution": {
    "type": "internal_handler",
    "handler": "sub_agent"
  },
  "ai": {
    "systemPromptSection": "### spawn_designer\nSpawn meta-reasoning planning agent.\n\n**Format:**\n```tool_request\n{\"tool\": \"spawn_designer\", \"query\": \"{\\\"task\\\": \\\"Design the new API architecture\\\"}\"}\n```\n\n**Parameters:**\n- task: What the designer should plan (required)\n- context_tags: Tags to focus the design\n- model_tier: 'capable' or 'fast' (default: capable)\n\n**Note:** Designers plan and decompose - uses capable model by default.",
    "usageExamples": [
      { "description": "Architecture planning", "input": "{\"task\": \"Design the plugin system architecture\"}" },
      { "description": "Task decomposition", "input": "{\"task\": \"Break down the migration into steps\", \"context_tags\": [\"migration\"]}" }
    ],
    "whenToUse": [
      "Complex architectural decisions",
      "Task decomposition",
      "Planning multi-step work"
    ],
    "whenNotToUse": [
      "Simple implementation tasks",
      "Quick fixes"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        { "param": "task", "widget": "textarea", "label": "Task", "placeholder": "What should the designer plan?", "rows": 3 },
        { "param": "context_tags", "widget": "tag_input", "label": "Context Tags" },
        { "param": "model_tier", "widget": "segmented", "label": "Model Tier", "options": [
          { "value": "capable", "label": "Capable" },
          { "value": "fast", "label": "Fast" }
        ]}
      ],
      "layout": "vertical",
      "submitLabel": "Spawn Designer"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        { "type": "header", "title": "Designer Spawned", "icon": "pencil.and.ruler" },
        { "type": "text", "source": "{{output}}" }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "agent_spawn",
    "approvalDescription": "Spawn Designer sub-agent",
    "scopes": ["agent.spawn"],
    "riskLevel": "medium"
  }
}
