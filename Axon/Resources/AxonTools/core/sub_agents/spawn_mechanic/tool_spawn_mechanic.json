{
  "version": "1.0.0",
  "tool": {
    "id": "spawn_mechanic",
    "name": "Spawn Mechanic",
    "description": "Spawn a read+write sub-agent for modification tasks.",
    "category": "sub_agents",
    "icon": { "sfSymbol": "wrench.and.screwdriver" },
    "requiresApproval": true,
    "tags": ["sub-agent", "mechanic", "modification", "read-write"]
  },
  "parameters": {
    "task": {
      "type": "string",
      "required": true,
      "description": "Task description for the mechanic"
    },
    "context_tags": {
      "type": "array",
      "required": false,
      "description": "Context tags to provide",
      "items": { "type": "string" }
    },
    "model_tier": {
      "type": "enum",
      "required": false,
      "description": "Model tier to use",
      "enum": ["capable", "fast"],
      "enumDescriptions": {
        "capable": "More capable model for complex tasks",
        "fast": "Faster model for simpler tasks"
      },
      "default": "fast"
    }
  },
  "inputFormat": { "style": "json" },
  "execution": {
    "type": "internal_handler",
    "handler": "sub_agent"
  },
  "ai": {
    "systemPromptSection": "### spawn_mechanic\nSpawn read+write modification agent.\n\n**Format:**\n```tool_request\n{\"tool\": \"spawn_mechanic\", \"query\": \"{\\\"task\\\": \\\"Fix the bug in auth module\\\"}\"}\n```\n\n**Parameters:**\n- task: What the mechanic should fix/modify (required)\n- context_tags: Tags to focus the work\n- model_tier: 'capable' or 'fast' (default: fast)\n\n**Note:** Mechanics can read and write - use for fixes and modifications.",
    "usageExamples": [
      { "description": "Fix bug", "input": "{\"task\": \"Fix the authentication timeout bug\"}" },
      { "description": "Refactor", "input": "{\"task\": \"Refactor error handling in API module\", \"model_tier\": \"capable\"}" }
    ],
    "whenToUse": [
      "Need isolated fixes",
      "Parallel implementation tasks",
      "Code modifications"
    ],
    "whenNotToUse": [
      "Read-only exploration (use scout)",
      "Complex architectural changes (use designer)"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        { "param": "task", "widget": "textarea", "label": "Task", "placeholder": "What should the mechanic fix/modify?", "rows": 3 },
        { "param": "context_tags", "widget": "tag_input", "label": "Context Tags" },
        { "param": "model_tier", "widget": "segmented", "label": "Model Tier", "options": [
          { "value": "fast", "label": "Fast" },
          { "value": "capable", "label": "Capable" }
        ]}
      ],
      "layout": "vertical",
      "submitLabel": "Spawn Mechanic"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        { "type": "header", "title": "Mechanic Spawned", "icon": "wrench.and.screwdriver" },
        { "type": "text", "source": "{{output}}" }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "agent_spawn",
    "approvalDescription": "Spawn Mechanic sub-agent",
    "scopes": ["agent.spawn", "file.write"],
    "riskLevel": "high"
  }
}
