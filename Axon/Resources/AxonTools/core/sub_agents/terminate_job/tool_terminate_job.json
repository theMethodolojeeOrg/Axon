{
  "version": "1.0.0",
  "tool": {
    "id": "terminate_job",
    "name": "Terminate Job",
    "description": "Terminate a running sub-agent job.",
    "category": "sub_agents",
    "icon": {
      "sfSymbol": "xmark.circle"
    },
    "requiresApproval": true,
    "tags": [
      "sub-agent",
      "job",
      "terminate",
      "cancel"
    ]
  },
  "parameters": {
    "job_id": {
      "type": "string",
      "required": true,
      "description": "Job ID to terminate"
    },
    "reason": {
      "type": "string",
      "required": false,
      "description": "Reason for termination"
    }
  },
  "inputFormat": {
    "style": "freeform"
  },
  "execution": {
    "type": "internal_handler",
    "handler": "sub_agent"
  },
  "ai": {
    "systemPromptSection": "### terminate_job\nTerminate running job.\n\n**Format:**\n```tool_request\n{\"tool\": \"terminate_job\", \"query\": \"{\\\"job_id\\\": \\\"job-abc\\\", \\\"reason\\\": \\\"No longer needed\\\"}\"}\n```\n\n**Parameters:**\n- job_id: Required\n- reason: Why terminating",
    "usageExamples": [
      {
        "description": "Cancel job",
        "input": "{\"job_id\": \"job-abc123\", \"reason\": \"No longer needed\"}"
      },
      {
        "description": "Timeout",
        "input": "{\"job_id\": \"job-abc123\", \"reason\": \"Taking too long\"}"
      }
    ],
    "whenToUse": [
      "Job no longer needed",
      "Job taking too long",
      "Wrong direction"
    ],
    "whenNotToUse": [
      "Job completing successfully"
    ]
  },
  "ui": {
    "inputForm": {
      "fields": [
        {
          "param": "job_id",
          "widget": "text_field",
          "label": "Job ID",
          "placeholder": "job-..."
        },
        {
          "param": "reason",
          "widget": "textarea",
          "label": "Reason",
          "placeholder": "Why terminate?",
          "rows": 2
        }
      ],
      "layout": "vertical",
      "submitLabel": "Terminate"
    },
    "resultDisplay": {
      "style": "card",
      "sections": [
        {
          "type": "header",
          "title": "Job Terminated",
          "icon": "xmark.circle"
        },
        {
          "type": "text",
          "source": "{{output}}"
        }
      ]
    }
  },
  "sovereignty": {
    "actionCategory": "agent_terminate",
    "approvalDescription": "Terminate job: {{job_id}}",
    "scopes": [
      "agent.terminate"
    ],
    "riskLevel": "medium"
  }
}