{
    "version": "1.0.0",
    "tool": {
        "id": "vscode_workspace_info",
        "name": "VS Code Workspace Info",
        "description": "Get information about the connected VS Code workspace including open files and folders.",
        "category": "vscode",
        "icon": {
            "sfSymbol": "rectangle.3.group.fill"
        },
        "requiresApproval": false,
        "tags": [
            "vscode",
            "workspace",
            "info",
            "project",
            "bridge"
        ]
    },
    "parameters": {},
    "inputFormat": {
        "style": "freeform"
    },
    "execution": {
