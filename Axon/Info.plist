<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UISupportsDocumentBrowser</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.axon.sync.conversations</string>
		<string>com.axon.sync.memories</string>
		<string>com.axon.sync.background</string>
	</array>
	<key>FirebaseAPIKey</key>
	<string>$(FIREBASE_API_KEY)</string>
	<key>FirebaseAppID</key>
	<string>$(FIREBASE_APP_ID)</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSBonjourServices</key>
	<array>
		<string>_axon-api._tcp</string>
	</array>
	<key>NSMicrophoneUsageDescription</key>
	<string>Axon uses the microphone for Live Mode to enable real-time voice conversations with AI.</string>
	<key>NSCameraUsageDescription</key>
	<string>Axon uses the camera to scan Axon Bridge QR codes for quick connection setup.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Axon uses speech recognition to transcribe your voice during Live Sessions for real-time AI conversations.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>processing</string>
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string></string>
		<key>UIImageName</key>
		<string></string>
	</dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.axon.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>axon</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
