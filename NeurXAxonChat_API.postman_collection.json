							"raw": "{\n  \"responseText\": \"Here's what I learned:\\n<memory type=\\\"fact\\\" confidence=\\\"0.9\\\">\\nPython uses indentation for blocks\\n</memory>\",\n  \"projectId\": \"{{projectId}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/memories/parse",
							"host": [
								"{{baseUrl}}"
							],
