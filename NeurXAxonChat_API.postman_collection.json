							"raw": "{\n  \"memories\": [\n    {\n      \"type\": \"fact\",\n      \"content\": \"Machine learning models require large datasets\",\n      \"confidence\": 0.8,\n      \"tags\": [\"ml\", \"data\"],\n      \"projectId\": \"{{projectId}}\"\n    },\n    {\n      \"type\": \"concept\",\n      \"content\": \"Python list comprehensions are concise ways to create lists\",\n      \"confidence\": 0.9,\n      \"tags\": [\"python\", \"list\"],\n      \"projectId\": \"{{projectId}}\"\n    }\n  ]\n}",
							"options": {
